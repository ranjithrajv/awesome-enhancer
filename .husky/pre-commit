#!/usr/bin/env bash
set -e

# Pre-commit hook that mirrors GitHub Actions CI checks
# This ensures all CI checks pass before committing

echo "🔍 Running pre-commit checks (mirroring GitHub Actions CI)..."
echo ""

# 1. Version check (release requirement)
echo "✓ Checking version consistency..."
bun --filter='@awesome-enhancer/core' run check-version

# 2. Tests (CI: bun.yml)
echo "✓ Running tests with coverage..."
bun run test:coverage

# 3. Type checking (CI: bun.yml, release.yml)
echo "✓ Running typecheck..."
bun run typecheck

# 4. Linting (CI: bun.yml, release.yml)
echo "✓ Running lint..."
bun run lint:all

# 5. Build + bundle verification (CI: bun.yml, pages.yml)
echo "✓ Running build (includes web bundle verification)..."
bun run build

# 6. Formatting check (CI: implicit in code quality)
echo "✓ Checking formatting..."
bun run format --check

# 7. Dead code/unused exports check (CI: code quality)
echo "✓ Checking for unused code (knip)..."
bunx knip --exclude dependencies,unlisted,binaries

echo ""
echo "✅ All pre-commit checks passed!"
echo "🚀 Ready to commit!"
