{
  "name": "awesome-enhancer",
  "version": "0.3.0",
  "type": "module",
  "description": "CLI tool to automatically enhance awesome lists with metadata and improved descriptions",
  "repository": {
    "type": "git",
    "url": "https://github.com/ranjithrajv/awesome-enhancer.git"
  },
  "bugs": {
    "url": "https://github.com/ranjithrajv/awesome-enhancer/issues?q=state%3Aopen+label%3Abug"
  },
  "homepage": "https://github.com/ranjithrajv/awesome-enhancer#readme",
  "main": "dist/src/index.js",
  "bin": {
    "awesome-enhancer": "dist/bin/cli.js",
    "awesome-enhancer-mcp": "dist/bin/mcp-server.js",
    "awesome-enhancer-server": "dist/bin/http-server.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "bun run bin/cli.tsx",
    "dev:server": "bun run bin/http-server.ts",
    "dev:mcp": "bun run bin/mcp-server.ts",
    "build": "bun run clean && rolldown -c rolldown.config.ts && bun run build:types",
    "build:types": "tsc --emitDeclarationOnly -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "bun run bin/cli.tsx tests/sample-awesome.md --dry-run --add-metadata",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --deny-warnings",
    "format": "prettier --write .",
    "prepare": "husky",
    "prepublishOnly": "bun run build"
  },
  "lint-staged": {
    "*.ts": [
      "oxlint --deny-warnings --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "awesome",
    "awesome-list",
    "cli",
    "markdown",
    "metadata",
    "github",
    "mcp",
    "ai-agent",
    "volunteer-computing"
  ],
  "author": "Ranjith Raj <ranjithraj@riseup.net>",
  "license": "AGPL-3.0-or-later",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "awesome-lint": "^2.2.3",
    "axios": "^1.13.3",
    "cheerio": "^1.2.0",
    "dotenv": "^17.2.3",
    "effect": "^3.19.19",
    "ink": "^6.8.0",
    "ink-select-input": "^6.2.0",
    "react": "^19.2.4",
    "remark": "^15.0.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.0",
    "unist-util-visit": "^5.0.0",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.0.18",
    "husky": "^9.1.7",
    "knip": "^5.82.1",
    "oxlint": "^1.41.0",
    "prettier": "^3.8.1",
    "rolldown": "^1.0.0-rc.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
