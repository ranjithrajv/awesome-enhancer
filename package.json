{
  "name": "awesome-enhancer-monorepo",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter='@awesome-enhancer/cli' dev",
    "dev:server": "bun run --filter='@awesome-enhancer/http-server' dev",
    "dev:mcp": "bun run --filter='@awesome-enhancer/mcp-server' dev",
    "build": "bun run --filter='@awesome-enhancer/*' build",
    "test": "vp test run",
    "test:watch": "vp test",
    "test:coverage": "vp test run --coverage",
    "lint": "vp lint",
    "lint:all": "bun run --filter='@awesome-enhancer/*' lint",
    "format": "prettier --write .",
    "typecheck": "bun run --filter='@awesome-enhancer/*' typecheck",
    "clean": "bun run --filter='@awesome-enhancer/*' clean",
    "clean:all": "bun run clean && rm -rf node_modules packages/*/node_modules"
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "@vitest/coverage-v8": "^4.0.18",
    "oxlint": "^1.41.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vite": "latest",
    "vite-plus": "^0.1.11",
    "vite-plugin-dts": "latest",
    "vitest": "latest"
  }
}
