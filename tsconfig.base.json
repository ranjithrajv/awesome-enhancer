{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "jsx": "react-jsx",
    "types": ["node"],
    "paths": {
      "@awesome-enhancer/core": ["./packages/core/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
